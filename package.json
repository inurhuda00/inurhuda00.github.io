{
    "name": "gh-pages",
    "version": "1.0.0",
    "scripts": {
        "dev": "next",
        "build": "next build",
        "start": "next start",
        "export": "next export",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
        "deploy": "rm -rf node_modules/.cache && next build && next export && touch out/.nojekyll && git add out/ && git commit -m \"Deploy Next.js to gh-pages\" && git subtree push --prefix out origin gh-pages"
    },
    "dependencies": {
        "@mapbox/rehype-prism": "^0.5.0",
        "@mdx-js/react": "^1.6.22",
        "@tailwindcss/typography": "^0.4.0",
        "classnames": "^2.2.6",
        "date-fns": "^2.17.0",
        "gray-matter": "^4.0.2",
        "mdx-prism": "^0.3.1",
        "next": "latest",
        "next-mdx-remote": "^2.1.3",
        "next-seo": "^4.19.0",
        "next-themes": "^0.0.10",
        "nextjs-progressbar": "^0.0.7",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "reading-time": "^1.3.0",
        "rehype": "^11.0.0",
        "remark-autolink-headings": "^6.0.1",
        "remark-code-titles": "^0.1.1",
        "remark-slug": "^6.0.0",
        "sass": "^1.32.8",
        "typescript": "^4.1.3"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/classnames": "^2.2.11",
        "@types/jest": "^26.0.20",
        "@types/mdx-js__react": "^1.5.3",
        "@types/node": "^14.14.25",
        "@types/react": "^17.0.1",
        "@types/react-dom": "^17.0.0",
        "autoprefixer": "^10.2.4",
        "babel-plugin-transform-define": "^2.0.0",
        "postcss": "^8.2.5",
        "prettier": "^2.2.1",
        "tailwindcss": "^2.0.3"
    },
    "prettier": {
        "tabWidth": 4,
        "useTabs": false,
        "singleQuote": true,
        "bracketSpacing": true,
        "semi": false,
        "printWidth": 90
    }
}
