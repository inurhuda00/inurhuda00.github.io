{
    "name": "gh-pages",
    "version": "1.0.0",
    "scripts": {
        "dev": "next",
        "build": "next build",
        "start": "next start",
        "export": "next export",
        "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
        "deploy": "rm -rf node_modules/.cache && next build && next export && touch out/.nojekyll && git add out/ && git commit -m \"Deploy Next.js to gh-pages\" && git subtree push --prefix out origin gh-pages"
    },
    "dependencies": {
        "classnames": "^2.2.6",
        "date-fns": "^2.17.0",
        "gray-matter": "^4.0.2",
        "next": "latest",
        "next-seo": "^4.19.0",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "remark": "^13.0.0",
        "remark-html": "^13.0.1",
        "typescript": "^4.1.3"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/classnames": "^2.2.11",
        "@types/jest": "^26.0.20",
        "@types/node": "^14.14.25",
        "@types/react": "^17.0.1",
        "@types/react-dom": "^17.0.0",
        "autoprefixer": "^10.2.4",
        "babel-plugin-transform-define": "^2.0.0",
        "postcss": "^8.2.5",
        "prettier": "^2.2.1",
        "tailwindcss": "^2.0.3"
    }
}
